---
---

<div
  id="memory-modal"
  class="fixed inset-0 z-[100] hidden items-center justify-center p-4 bg-black/85 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-labelledby="memory-title"
>
  <div class="relative bg-surface-800 border border-magenta-500/20 max-w-sm w-full overflow-hidden shadow-2xl">

    <!-- Close button -->
    <button
      id="memory-close"
      class="absolute top-3 right-3 z-10 w-9 h-9 flex items-center justify-center text-white/60 hover:text-white text-2xl leading-none transition-colors"
      aria-label="Close"
    >
      &times;
    </button>

    <!-- Headshot -->
    <div class="relative">
      <img
        src="/images/tribute/00-headshot.jpg"
        alt="Ralph J. Molé"
        class="w-full h-60 object-cover object-top grayscale"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-surface-800 via-transparent to-transparent"></div>
    </div>

    <!-- Text -->
    <div class="px-7 pt-3 pb-7 text-center">
      <p class="text-magenta-500 text-[10px] tracking-[0.5em] uppercase font-medium mb-3">
        In Loving Memory
      </p>
      <h2 id="memory-title" class="font-serif italic text-white text-3xl mb-1 leading-tight">
        Ralph J. Molé
      </h2>
      <p class="text-gray-400 text-sm tracking-[0.3em] mb-6">1949 &mdash; 2022</p>

      <div class="w-12 h-px bg-magenta-500 mx-auto mb-6"></div>

      <p class="text-gray-400 text-sm leading-relaxed font-light mb-8">
        Founder of Windfall Productions. A husband, father, and mentor whose
        legacy lives on through every broadcast he touched.
      </p>

      <div class="flex flex-col gap-3">
        <a
          href="/tribute"
          id="memory-learn-more"
          class="px-6 py-3 bg-magenta-500 hover:bg-magenta-600 text-white font-semibold text-xs tracking-widest uppercase transition-colors"
        >
          Learn More
        </a>
        <button
          id="memory-dismiss"
          class="text-gray-500 hover:text-white text-xs tracking-widest uppercase font-medium transition-colors py-2"
        >
          Continue to Site
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  const VIEWS_KEY = 'wfp-tribute-views';
  const SESSION_KEY = 'wfp-tribute-shown-session';
  const MAX_VIEWS = 5;
  const modal = document.getElementById('memory-modal');
  const closeBtn = document.getElementById('memory-close');
  const dismissBtn = document.getElementById('memory-dismiss');
  const learnMoreBtn = document.getElementById('memory-learn-more');

  function getViews(): number {
    try { return parseInt(localStorage.getItem(VIEWS_KEY) || '0', 10) || 0; } catch { return 0; }
  }

  function incrementViews() {
    try { localStorage.setItem(VIEWS_KEY, String(getViews() + 1)); } catch {}
  }

  function shownThisSession(): boolean {
    try { return sessionStorage.getItem(SESSION_KEY) === '1'; } catch { return false; }
  }

  function markShownThisSession() {
    try { sessionStorage.setItem(SESSION_KEY, '1'); } catch {}
  }

  function open() {
    if (!modal) return;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    if (!modal) return;
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
  }

  // Show once per browser session, up to MAX_VIEWS distinct sessions
  if (!shownThisSession() && getViews() < MAX_VIEWS) {
    setTimeout(() => {
      open();
      incrementViews();
      markShownThisSession();
    }, 600);
  }

  closeBtn?.addEventListener('click', close);
  dismissBtn?.addEventListener('click', close);
  learnMoreBtn?.addEventListener('click', () => {
    markShownThisSession();
    close();
  });

  // Click outside to close
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) close();
  });

  // Esc to close
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal?.classList.contains('hidden')) close();
  });
</script>
