---
interface Props {
  category: string;
  height?: string;
}

const { category, height = 'h-40' } = Astro.props;

// Lucide-style stroked icons — inner SVG content (paths/circles, no strokes set inline)
const icons: Record<string, string> = {
  // Track & Field — stopwatch
  stopwatch: '<circle cx="12" cy="14" r="8" /><line x1="9" y1="2" x2="15" y2="2" /><line x1="12" y1="14" x2="12" y2="9" /><line x1="12" y1="14" x2="15.5" y2="14" /><line x1="18" y1="6" x2="20" y2="4" />',

  // Generic — trophy
  trophy: '<path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6" /><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18" /><path d="M4 22h16" /><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22" /><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22" /><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z" />',

  // Speed / motorsports — bolt
  bolt: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />',

  // Olympics — medal
  medal: '<path d="M7.21 15 2.66 7.14a2 2 0 0 1 .13-2.2L4.4 2.8A2 2 0 0 1 6 2h12a2 2 0 0 1 1.6.8l1.6 2.14a2 2 0 0 1 .14 2.2L16.79 15" /><path d="M11 12 5.12 2.2" /><path d="m13 12 5.88-9.8" /><path d="M8 7h8" /><circle cx="12" cy="17" r="5" /><path d="M12 18v-2h-.5" />',

  // Racing — fast-forward chevrons
  chevrons: '<polyline points="13 17 18 12 13 7" /><polyline points="6 17 11 12 6 7" />',

  // Tennis — tennis ball
  tennis: '<circle cx="12" cy="12" r="10" /><path d="M5 6.5a14.4 14.4 0 0 1 14 0" /><path d="M5 17.5a14.4 14.4 0 0 0 14 0" />',

  // Cycling — bicycle
  bicycle: '<circle cx="5.5" cy="17.5" r="3.5" /><circle cx="18.5" cy="17.5" r="3.5" /><path d="M15 6a1 1 0 1 0 0-2 1 1 0 0 0 0 2z" /><path d="M12 17.5V14l-3-3 4-3 2 3h2" />',

  // Skiing
  ski: '<path d="M2 19a3 3 0 0 1 3-3h14a3 3 0 0 1 3 3" /><path d="M5 19v2" /><path d="M19 19v2" /><circle cx="12" cy="6" r="3" /><path d="M12 9v7" />',

  // Sailing — sailboat
  sailing: '<path d="M2 20a2.4 2.4 0 0 0 2 1 2.4 2.4 0 0 0 2-1 2.4 2.4 0 0 1 2-1 2.4 2.4 0 0 1 2 1 2.4 2.4 0 0 0 2 1 2.4 2.4 0 0 0 2-1 2.4 2.4 0 0 1 2-1 2.4 2.4 0 0 1 2 1 2.4 2.4 0 0 0 2 1 2.4 2.4 0 0 0 2-1" /><path d="M4 18l-2-3h20l-3 3" /><path d="M11 3 4 15h17L14 3a2 2 0 0 0-3 0Z" />',

  // Soccer — soccer ball
  soccer: '<circle cx="12" cy="12" r="10" /><polygon points="12 7 16 10 14.5 14.5 9.5 14.5 8 10" />',

  // Hockey — hockey puck/stick
  hockey: '<path d="M3 18l8-14 4 7-4 7H3z" /><path d="M11 11l8-7" /><ellipse cx="18" cy="18" rx="4" ry="1.5" />',

  // Golf — flag in green
  golfflag: '<path d="M6 3v19" /><path d="M6 5l13 4-13 4" /><circle cx="6" cy="20" r="2" />',

  // Documentary — film strip
  film: '<rect x="2" y="3" width="20" height="18" rx="2" /><line x1="2" y1="9" x2="22" y2="9" /><line x1="2" y1="15" x2="22" y2="15" /><line x1="7" y1="3" x2="7" y2="21" /><line x1="17" y1="3" x2="17" y2="21" />',

  // Entertainment — play button (universal TV/media symbol)
  play: '<circle cx="12" cy="12" r="10" /><polygon points="10 8 16 12 10 16 10 8" />',

  // Star
  star: '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />',

  // Award/medal ribbon
  award: '<circle cx="12" cy="8" r="6" /><polyline points="8.21 13.89 7 22 12 19 17 22 15.79 13.88" />',

  // Corporate building
  building: '<rect x="4" y="2" width="16" height="20" rx="1" /><path d="M9 22v-4h6v4" /><path d="M8 6h.01" /><path d="M16 6h.01" /><path d="M12 6h.01" /><path d="M12 10h.01" /><path d="M12 14h.01" /><path d="M16 10h.01" /><path d="M16 14h.01" /><path d="M8 10h.01" /><path d="M8 14h.01" />',
};

const categoryConfig: Record<string, { icon: string; label: string }> = {
  'track & field': { icon: 'stopwatch', label: 'Track & Field' },
  'track and field': { icon: 'stopwatch', label: 'Track & Field' },
  'tennis': { icon: 'tennis', label: 'Tennis' },
  'cycling': { icon: 'bicycle', label: 'Cycling' },
  'skiing': { icon: 'ski', label: 'Alpine' },
  'motorsports': { icon: 'bolt', label: 'Motorsports' },
  'racing': { icon: 'chevrons', label: 'Racing' },
  'sailing': { icon: 'sailing', label: 'Sailing' },
  'soccer': { icon: 'soccer', label: 'Soccer' },
  'hockey': { icon: 'hockey', label: 'Hockey' },
  'golf': { icon: 'golfflag', label: 'Golf' },
  'figure skating': { icon: 'star', label: 'Figure Skating' },
  'documentary': { icon: 'film', label: 'Documentary' },
  'entertainment': { icon: 'play', label: 'Entertainment' },
  'corporate': { icon: 'building', label: 'Corporate' },
  'awards': { icon: 'award', label: 'Awards' },
  'live events': { icon: 'star', label: 'Live Event' },
  'technology': { icon: 'film', label: 'Technology' },
  'olympic sports': { icon: 'medal', label: 'Olympic' },
  'action sports': { icon: 'bolt', label: 'Action Sports' },
};

const cfg = categoryConfig[category.toLowerCase()] ?? { icon: 'trophy', label: category };
const iconSvg = icons[cfg.icon] ?? icons.trophy;

const seed = category.split('').reduce((a, c) => a + c.charCodeAt(0), 0);
const angle = (seed * 17) % 360;
const offset = (seed * 23) % 30;
---

<div class={`relative ${height} overflow-hidden bg-surface-700`}>
  <div
    class="absolute inset-0"
    style={`background: linear-gradient(${angle}deg, #1a1a1a 0%, #2d0030 ${50 + offset}%, #4a004a 100%);`}
  ></div>

  <div
    class="absolute inset-0 opacity-[0.08]"
    style="background-image: repeating-linear-gradient(45deg, transparent 0, transparent 10px, #fff 10px, #fff 11px);"
  ></div>

  <div
    class="absolute -top-10 -right-10 w-40 h-40 rounded-full opacity-20"
    style="background: radial-gradient(circle, #F500F5 0%, transparent 70%);"
  ></div>

  <!-- Large center icon (stroke-based, faded magenta) -->
  <div class="absolute inset-0 flex items-center justify-center">
    <svg
      width="100"
      height="100"
      viewBox="0 0 24 24"
      class="text-magenta-500/35"
      fill="none"
      stroke="currentColor"
      stroke-width="1.4"
      stroke-linecap="round"
      stroke-linejoin="round"
      set:html={iconSvg}
    />
  </div>

  <!-- Small badge label, bottom-left -->
  <div class="absolute bottom-3 left-4 flex items-center gap-2">
    <svg
      width="14"
      height="14"
      viewBox="0 0 24 24"
      class="text-magenta-500"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      set:html={iconSvg}
    />
    <span class="text-[10px] tracking-[0.3em] uppercase text-white/60 font-medium">{cfg.label}</span>
  </div>
</div>
