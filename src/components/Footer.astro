---
const year = new Date().getFullYear();
---

<footer class="bg-surface-900 border-t border-white/5 py-10">
  <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-6">
    <img
      src="/images/wfp-logo-vector-white.svg"
      alt="Windfall Productions LLC"
      class="h-10 w-auto opacity-80"
    />
    <p class="text-gray-700 text-xs tracking-wider">
      &copy; {year} Windfall Productions LLC. All rights reserved.
    </p>
  </div>
</footer>
