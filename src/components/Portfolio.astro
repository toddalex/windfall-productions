      { title: 'Windfall Action Sports', client: 'ESPN X Games / World Sports Mktg', detail: '17 Winter & Summer X-Games; BMX, freestyle motocross, skateboarding', img: '/images/portfolio/project1.jpg', tag: 'Action Sports' },
    ],
