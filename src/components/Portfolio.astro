---

<section id="portfolio" class="py-28 bg-surface-800">
  <div class="max-w-7xl mx-auto px-6">

    <div class="flex items-center gap-4 mb-4">
      <div class="w-8 h-[2px] bg-magenta-500"></div>
      <span class="text-magenta-500 text-xs tracking-[0.4em] uppercase font-medium">Portfolio</span>
    </div>

    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
      <h2 class="font-serif italic text-5xl md:text-6xl text-white leading-tight">Our Work</h2>
      <p class="text-gray-500 max-w-sm text-base font-light leading-relaxed">
        27 productions across four decades live events, TV specials, documentaries, and corporate films.
      </p>
    </div>

    <!-- Category tabs -->
    <div class="flex flex-wrap gap-2 mb-10" id="portfolio-tabs">
      {categories.map((cat, i) => (
        <button
          data-tab={cat.id}
          class={`px-4 py-2 text-xs tracking-widest uppercase font-medium transition-colors tab-btn ${i === 0 ? 'bg-magenta-500 text-white' : 'border border-white/15 text-gray-400 hover:border-magenta-500 hover:text-magenta-400'}`}
        >
          {cat.label}
        </button>
      ))}
    </div>

    <!-- Category panels -->
    {categories.map((cat, i) => (
      <div id={`panel-${cat.id}`} class={`portfolio-panel ${i !== 0 ? 'hidden' : ''}`}>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {cat.items.map((item) => (
            <div class="group bg-surface-700 border border-white/5 hover:border-magenta-500/30 transition-all duration-200 overflow-hidden">
              {item.img ? (
                <div class="h-40 overflow-hidden">
                  <img
                    src={item.img}
                    alt={item.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                </div>
              ) : (
                <CategoryPlaceholder category={item.tag} />
              )}
              <div class="p-6">
                <p class="text-magenta-500 text-[10px] tracking-[0.3em] uppercase font-medium mb-1">{item.client}</p>
                <h3 class="text-white font-medium text-base mb-2 leading-snug">{item.title}</h3>
                <p class="text-gray-500 text-xs leading-relaxed">{item.detail}</p>
                {'video' in item && item.video && (
                  <a
                    href={item.video}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1.5 mt-3 text-magenta-500 hover:text-magenta-400 text-xs tracking-wider uppercase transition-colors"
                  >
                    <span class="text-[10px]">▶</span> Watch
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const panels = document.querySelectorAll<HTMLDivElement>('.portfolio-panel');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;
      tabs.forEach((t) => {
        t.classList.remove('bg-magenta-500', 'text-white');
        t.classList.add('border', 'border-white/15', 'text-gray-400');
      });
      tab.classList.add('bg-magenta-500', 'text-white');
      tab.classList.remove('border', 'border-white/15', 'text-gray-400');
      panels.forEach((panel) => {
        panel.classList.toggle('hidden', panel.id !== `panel-${target}`);
      });
    });
  });
</script>
