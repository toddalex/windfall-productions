      { title: 'Tour DuPont 1995', client: 'Medalist Sports', detail: 'Lance Armstrong (age 23) wins 1,130-mile stage race', img: null, tag: 'Cycling' },
      { title: 'Coors International Cycling Classic', client: 'FCB Telecom', detail: 'San Francisco, Napa, Aspen, Vail, Grand Junction Windfall\'s intro to world-class cycling', img: '/images/portfolio/dh-racer.jpg', tag: 'Cycling' },
