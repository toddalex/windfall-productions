---
const socials = [
  { label: 'Facebook', href: 'https://facebook.com/windfallproductions', icon: 'f' },
  { label: 'YouTube', href: 'https://youtube.com/user/ralphjmole', icon: '▶' },
  { label: 'LinkedIn', href: 'https://linkedin.com/in/ralphjmolewindfallproductions', icon: 'in' },
  { label: 'Twitter / X', href: 'https://twitter.com/ralphjmole', icon: '𝕏' },
  { label: 'Pinterest', href: 'https://pinterest.com/windfalltv', icon: '⊕' },
];
---

<section id="contact" class="py-28 bg-surface-800">
  <div class="max-w-7xl mx-auto px-6">

    <div class="flex items-center gap-4 mb-4">
      <div class="w-8 h-[2px] bg-magenta-500"></div>
      <span class="text-magenta-500 text-xs tracking-[0.4em] uppercase font-medium">Contact</span>
    </div>

    <div class="grid lg:grid-cols-2 gap-16">
      <!-- Left -->
      <div>
        <h2 class="font-serif italic text-5xl md:text-6xl text-white mb-8 leading-tight">
          Let's Create <br />
          <span class="not-italic font-sans font-black text-magenta-500">Something</span>
        </h2>
        <p class="text-gray-400 text-lg font-light leading-relaxed mb-10">
          Planning a live broadcast, a TV special, or a documentary?
          Windfall Productions brings four decades of network television
          expertise to every production.
        </p>

        <div class="space-y-5 mb-10">
          <div>
            <p class="text-gray-600 text-xs tracking-[0.3em] uppercase mb-1">General Inquiries</p>
            <a href="mailto:info@windfallproductions.com" class="text-white hover:text-magenta-400 transition-colors font-medium">
              info@windfallproductions.com
            </a>
          </div>
        </div>

        <div>
          <p class="text-gray-600 text-xs tracking-[0.3em] uppercase mb-4">Follow Along</p>
          <div class="flex gap-3">
            {socials.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                class="w-10 h-10 border border-white/15 hover:border-magenta-500 hover:text-magenta-400 text-gray-500 flex items-center justify-center text-sm transition-colors"
                aria-label={s.label}
              >
                {s.icon}
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Right: Contact form (mailto fallback for static hosting) -->
      <form
        id="contact-form"
        action="mailto:info@windfallproductions.com"
        method="POST"
        enctype="text/plain"
        class="space-y-5"
      >

        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label for="name" class="block text-gray-600 text-xs tracking-[0.3em] uppercase mb-2">Name</label>
            <input
              id="name" name="name" type="text" required
              class="w-full bg-surface-700 border border-white/10 focus:border-magenta-500 text-white placeholder-gray-700 px-4 py-3 text-sm outline-none transition-colors"
              placeholder="Your name"
            />
          </div>
          <div>
            <label for="email" class="block text-gray-600 text-xs tracking-[0.3em] uppercase mb-2">Email</label>
            <input
              id="email" name="email" type="email" required
              class="w-full bg-surface-700 border border-white/10 focus:border-magenta-500 text-white placeholder-gray-700 px-4 py-3 text-sm outline-none transition-colors"
              placeholder="your@email.com"
            />
          </div>
        </div>

        <div>
          <label for="subject" class="block text-gray-600 text-xs tracking-[0.3em] uppercase mb-2">Subject</label>
          <input
            id="subject" name="subject" type="text"
            class="w-full bg-surface-700 border border-white/10 focus:border-magenta-500 text-white placeholder-gray-700 px-4 py-3 text-sm outline-none transition-colors"
            placeholder="Production inquiry, partnership, etc."
          />
        </div>

        <div>
          <label for="message" class="block text-gray-600 text-xs tracking-[0.3em] uppercase mb-2">Message</label>
          <textarea
            id="message" name="message" required rows="5"
            class="w-full bg-surface-700 border border-white/10 focus:border-magenta-500 text-white placeholder-gray-700 px-4 py-3 text-sm outline-none transition-colors resize-none"
            placeholder="Tell us about your project..."
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full py-4 bg-magenta-500 hover:bg-magenta-600 text-white font-semibold text-sm tracking-widest uppercase transition-colors"
        >
          Send Message
        </button>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const name = (data.get('name') as string) || '';
    const email = (data.get('email') as string) || '';
    const subject = (data.get('subject') as string) || 'Windfall Productions inquiry';
    const message = (data.get('message') as string) || '';

    const body = `${message}\n\n—\nFrom: ${name}\nReply to: ${email}`;
    const href = `mailto:info@windfallproductions.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    window.location.href = href;
  });
</script>
